# Environment Configuration

# Server configuration
# PORT=8080

# Environment: dev enables GraphQL introspection
# ENV=dev

# PostgreSQL connection string
# Format: postgres://user:password@host:port/database?sslmode=mode
# DB_URL=postgres://postgres:password@localhost:5432/jobboard?sslmode=disable

# JWT secret key - must be at least 32 characters
# Generate with: openssl rand -base64 32
# SECRET_JWT=your-very-long-and-secure-secret-key-at-least-32-chars
